#!/usr/bin/env bash
# Owns: launching `claude` with the backend selected by the saved mode.
# Does NOT own: storing keys (Keychain via setup-cc-switcher.sh) or starting
#               the proxy server (delegates to scripts/start.sh).
# Called by: the user, directly or via the `cc` symlink in ~/.local/bin.
# Calls:     `security` (Keychain), curl (health probe), scripts/start.sh,
#            jq (reads settings.json), and finally `claude` via exec.
#
# Mode is read from ~/.claude/settings.json env.ANTHROPIC_BASE_URL (counterpart
# writer: scripts/cc-set-api-mode.sh). When set to the proxy URL, proxy mode is
# used. Missing or unset => direct, since that's the safer default.
set -euo pipefail

readonly SETTINGS="$HOME/.claude/settings.json"
readonly KEYCHAIN_DIRECT="free-claude-code/anthropic-direct"
readonly KEYCHAIN_PROXY="free-claude-code/proxy-auth"
readonly PROXY_HOST="${HOST:-127.0.0.1}"
readonly PROXY_PORT="${PORT:-8082}"
readonly PROXY_BASE_URL="http://$PROXY_HOST:$PROXY_PORT"

repo_root() {
    local source="${BASH_SOURCE[0]}"
    # Resolve symlink so ~/.local/bin/cc finds the real scripts/ dir.
    while [[ -L "$source" ]]; do
        local dir
        dir="$(cd -P "$(dirname "$source")" && pwd)"
        source="$(readlink "$source")"
        [[ "$source" != /* ]] && source="$dir/$source"
    done
    cd -P "$(dirname "$source")/.." && pwd
}

read_mode() {
    if command -v jq &>/dev/null && [[ -f "$SETTINGS" ]]; then
        local url
        url="$(jq -r '.env.ANTHROPIC_BASE_URL // empty' "$SETTINGS" 2>/dev/null)"
        if [[ "$url" == "$PROXY_BASE_URL" ]]; then
            printf 'proxy'; return
        fi
    fi
    printf 'direct'
}

fetch_keychain() {
    local service="$1"
    if ! security find-generic-password -a "$USER" -s "$service" -w 2>/dev/null; then
        echo "cc: missing Keychain entry '$service' for user '$USER'." >&2
        echo "cc: run scripts/setup-cc-switcher.sh to create it." >&2
        exit 1
    fi
}

ensure_proxy_running() {
    if curl -fsS --max-time 2 "$PROXY_BASE_URL/health" >/dev/null 2>&1; then
        return
    fi
    echo "cc: proxy not responding on $PROXY_BASE_URL — starting it..." >&2
    HOST="$PROXY_HOST" PORT="$PROXY_PORT" bash "$(repo_root)/scripts/start.sh" >&2
}

launch_proxy_mode() {
    ensure_proxy_running
    local token
    token="$(fetch_keychain "$KEYCHAIN_PROXY")"
    export ANTHROPIC_BASE_URL="$PROXY_BASE_URL"
    export ANTHROPIC_API_KEY="$token"
    exec claude "$@"
}

launch_direct_mode() {
    local key
    key="$(fetch_keychain "$KEYCHAIN_DIRECT")"
    # Stale ANTHROPIC_BASE_URL would silently route to a proxy.
    unset ANTHROPIC_BASE_URL
    export ANTHROPIC_API_KEY="$key"
    exec claude "$@"
}

main() {
    local mode
    mode="$(read_mode)"
    case "$mode" in
        proxy)  launch_proxy_mode  "$@" ;;
        direct) launch_direct_mode "$@" ;;
        *)      echo "cc: unreachable mode '$mode'" >&2; exit 2 ;;
    esac
}

main "$@"
