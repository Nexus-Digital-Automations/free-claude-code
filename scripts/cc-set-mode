#!/usr/bin/env bash
# Owns: writing the mode marker that `cc` reads on next launch.
# Does NOT own: applying the mode (that requires a `claude` restart via `cc`).
# Called by: the /use-proxy and /use-direct slash commands.
# Calls:     nothing — pure file write.
set -euo pipefail

readonly MODE_FILE="${XDG_CONFIG_HOME:-$HOME/.config}/free-claude-code/mode"

if [[ $# -ne 1 ]]; then
    echo "usage: cc-set-mode {proxy|direct}" >&2
    exit 2
fi

mode="$1"
case "$mode" in
    proxy|direct) ;;
    *) echo "cc-set-mode: unknown mode '$mode' (expected 'proxy' or 'direct')" >&2; exit 2 ;;
esac

mkdir -p "$(dirname "$MODE_FILE")"
printf '%s\n' "$mode" > "$MODE_FILE"

echo "Mode set to: $mode"
echo "Exit this Claude Code session (Ctrl+D) and run \`cc\` to apply."
