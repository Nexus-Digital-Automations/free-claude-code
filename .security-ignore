# False-positive suppressions for the security scan.
# Production-code false positives are suppressed with inline
# `# pragma: allowlist secret` comments rather than file-level entries here,
# so reviewers can see exactly which lines are exempted and why.

# Test fixtures use fake/placeholder API keys and passwords by design.
# Real credentials are never present in this directory.
tests/**

# README contains illustrative example values only, not deployable credentials.
README.md

# .env.example is documentation for required variables; values are placeholders.
.env.example

# Runtime log files may contain session metadata; they are gitignored and
# never committed. No deployable secrets are stored here.
logs/**

# Provider dependency file. Lines 100 and 114 set placeholder api_key values
# ("lm-studio", "llamacpp") required by the OpenAI SDK but ignored by these
# local servers. Both lines carry inline `# pragma: allowlist secret` comments.
# pattern-scanner does not honor inline suppression, so this file-level entry
# is required for that tool.
api/dependencies.py

# Background Ollama compaction client. Line 327 sets api_key="ollama" as a
# placeholder required by the OpenAI SDK; Ollama's server ignores it.
# Inline `# pragma: allowlist secret` comment is present. detect-secrets does
# not pick up the pragma here (no baseline file in repo), so this entry covers
# that tool.
providers/common/context_optimizer.py
